#!/bin/sh
# AgentOS pre-push hook
# Runs full checks before pushing.

echo "=== AgentOS Pre-Push Checks ==="
echo ""

echo "→ Running cargo check..."
cargo check --workspace 2>&1 || exit 1

echo ""
echo "→ Running cargo test..."
cargo test --workspace 2>&1 || exit 1

echo ""
echo "→ Running cargo audit..."
cargo audit 2>&1 || if [ $? -eq 127 ]; then echo "(cargo-audit not installed, skipping)"; else exit 1; fi

echo ""
echo "=== All checks passed! ==="
