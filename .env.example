# ── AgentOS Environment Configuration ──────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
#
# Security notice: API keys and secrets set via environment variables
# are visible in process listings. Prefer managed secret injection for
# production deployments.

# ── LLM Provider: OpenAI ──────────────────────────────────────────────
# Required for OpenAI-compatible LLM backends
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── LLM Provider: Anthropic ───────────────────────────────────────────
# Required for Anthropic Claude LLM backends
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── LLM Provider: Ollama (local) ──────────────────────────────────────
# Optional for local LLM inference
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── LLM Provider Selection ────────────────────────────────────────────
# Which provider the runtime uses for agent execution steps:
#   auto      - first configured of OpenAI, then Anthropic (default)
#   openai    - require OPENAI_API_KEY
#   anthropic - require ANTHROPIC_API_KEY
#   ollama    - use the local Ollama endpoint
# If no provider is configured, agentOS run supervises the agent without
# executing an LLM step.
AGENTOS_LLM_PROVIDER=auto

# ── Runtime Configuration ────────────────────────────────────────────
# Network bind address (default: 127.0.0.1 — bind to 0.0.0.0 only
# when behind a properly configured reverse proxy with authentication)
AGENTOS_HOST=127.0.0.1

# HTTP health/API port
AGENTOS_HTTP_PORT=8080

# gRPC bus port
AGENTOS_GRPC_PORT=50051

# SSE event stream port (dashboard live events at /events)
AGENTOS_SSE_PORT=8081

# Maximum supervised agents
AGENTOS_MAX_AGENTS=100

# Log level (trace, debug, info, warn, error)
AGENTOS_LOG_LEVEL=info

# Runtime data directory (for SQLite state, traces, etc.)
AGENTOS_DATA_DIR=data

# State backend (json or sqlite)
AGENTOS_STATE_BACKEND=sqlite

# ── Security ──────────────────────────────────────────────────────────
# Shared API token. When set, /metrics, the inspection API, the bus
# Publish/Subscribe endpoints, and the SSE event stream all require
# "Authorization: Bearer <token>" (SSE also accepts ?token=). Liveness
# endpoints (/health*) stay open for container healthchecks.
# When unset, all surfaces are open — keep the default localhost bind.
AGENTOS_API_TOKEN=

# AES-256-GCM key for encrypted vault persistence (64 hex chars, 32 bytes).
# When set, secrets stored via the runtime are persisted encrypted under
# AGENTOS_DATA_DIR/vault/secrets.enc and restored on startup. When unset,
# secrets are held in memory only and nothing is written to disk.
# Generate one:  openssl rand -hex 32
AGENTOS_VAULT_KEY=
