{
  "name": "@agentos/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for AgentOS - Build agents and interact with the AgentOS runtime",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
